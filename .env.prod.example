# ──────────────────────────────────────────────────────────────
# Plantilla del .env de PRODUCCIÓN (VPS). Copiar a `.env.prod` EN EL SERVIDOR
# (/root/motogestion/.env.prod) y rellenar con valores reales.
# NO commitear el .env.prod real (está en .gitignore / .dockerignore).
# ──────────────────────────────────────────────────────────────

# --- Base de datos (contenedor `postgres` en la red root_default del VPS) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=motogestion
DB_USER=motogestion
DB_PASSWORD=9awZqiv7RlffAY6xh0Et

# --- App ---
# environment=prod OCULTA /docs. Usa "dev" temporalmente si quieres ver Swagger.
environment=prod
project_name=moto-api
# Dominio del FRONT (CORS). Ajusta cuando definas dónde corre el front.
allowed_origin=https://motogestion.miclickderecho.com
frontend_url=https://motogestion.miclickderecho.com

# --- Auth0 ---
# De momento puedes usar los valores del tenant de DEV (el backend arranca y
# valida tokens contra ese tenant). Cuando crees el tenant de PROD, los cambias.
AUTH0_DOMAIN=dev-q4srpexn6ajjjfqs.us.auth0.com
AUTH0_API_AUDIENCE=https://moto.com/api
AUTH0_ALGORITHMS=RS256
AUTH0_MANAGEMENT_CLIENT_ID=__m2m_client_id__
AUTH0_MANAGEMENT_CLIENT_SECRET=__m2m_client_secret__
AUTH0_MANAGEMENT_AUDIENCE=https://dev-q4srpexn6ajjjfqs.us.auth0.com/api/v2/
AUTH0_CONNECTION_ID=Username-Password-Authentication
AUTH0_CUSTOMER_ROLE=rol_dIiGAjLgoofCr3Hm
AUTH0_ADMIN_ROLE=rol_dIiGAjLgoofCr3Hm
