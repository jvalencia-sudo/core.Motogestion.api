#: templates/new_file_uploaded_email_template.html:6
msgid "New File Uploaded"
msgstr "Nuevo Archivo Subido"

#: templates/new_file_uploaded_email_template.html:11
#: templates/status_update_email_template.html:11
#: templates/file_version_update_email_template.html:11
#: templates/order_message_email_template.html:11
#, python-format
msgid "Dear %(client)s,"
msgstr "Estimado/a %(client)s,"

#: templates/new_file_uploaded_email_template.html:12
#, python-format
msgid "A new file has been uploaded to your order #%(order)s."
msgstr "Se ha subido un nuevo archivo a su pedido #%(order)s."

#: templates/file_version_update_email_template.html:6
msgid "File Version Update"
msgstr "Actualización de Versión de Archivo"

#: templates/file_version_update_email_template.html:12
#, python-format
msgid "A new version of a file has been uploaded for your order #%(order)s."
msgstr "Se ha subido una nueva versión de un archivo para su pedido #%(order)s."

#: templates/order_message_email_template.html:6
msgid "New Order Message"
msgstr "Nuevo Mensaje de Pedido"

#: templates/order_message_email_template.html:14
#, python-format
msgid "A new message has been posted regarding your order #%(order)s."
msgstr "Se ha publicado un nuevo mensaje sobre su pedido #%(order)s."

#: templates/order_message_email_template.html:20
msgid "Message From"
msgstr "Mensaje de"

#: templates/order_message_email_template.html:24
msgid "Posted On"
msgstr "Publicado el"

#: templates/order_message_email_template.html:33
#, python-format
msgid "The following message was posted on your order: %(message)s"
msgstr "El siguiente mensaje fue publicado en su pedido: %(message)s"

#: templates/new_file_uploaded_email_template.html:17
msgid "File Name"
msgstr "Nombre del archivo"

#: templates/new_file_uploaded_email_template.html:21
msgid "Uploaded By"
msgstr "Subido por"

#: templates/new_file_uploaded_email_template.html:25
msgid "Uploaded On"
msgstr "Subido el"

#: templates/file_version_update_email_template.html:21
msgid "Version"
msgstr "Versión"

#: templates/new_file_uploaded_email_template.html:41
msgid "This file has been added to your order and is now available for your review. You can access this file by logging into your account and viewing your order details."
msgstr "Este archivo ha sido agregado a su pedido y ahora está disponible para su revisión. Puede acceder a este archivo iniciando sesión en su cuenta y viendo los detalles de su pedido."

#: templates/new_file_uploaded_email_template.html:51
msgid "If you have any questions about this file or need to request any changes, please don't hesitate to contact our customer support team."
msgstr "Si tiene alguna pregunta sobre este archivo o necesita solicitar cambios, no dude en contactar a nuestro equipo."

#: templates/new_file_uploaded_email_template.html:45
#: templates/status_update_email_template.html:36
#: templates/file_version_update_email_template.html:45
#: templates/order_message_email_template.html:45
msgid "Thank you for your business!"
msgstr "¡Gracias por su negocio!"

#: templates/new_file_uploaded_email_template.html:48
#: templates/status_update_email_template.html:38
#: templates/file_version_update_email_template.html:48
#: templates/order_message_email_template.html:48
