msgstr "Recibió este correo porque tiene un pedido activo con nosotros."

#: templates/status_update_email_template.html:12
#, python-format
msgid "We have an update regarding your order #%(order)s."
msgstr "Tenemos una actualización sobre su pedido #%(order)s."

#: templates/status_update_email_template.html:17
msgid "Order Status"
msgstr "Estado del pedido"

#: templates/status_update_email_template.html:21
msgid "Updated On"
msgstr "Actualizado el"

#: templates/status_update_email_template.html:25
msgid "Step"
msgstr "Paso"

#: templates/status_update_email_template.html:34
#: templates/file_version_update_email_template.html:41
#: templates/order_message_email_template.html:38
msgid "If you have any questions or concerns, please don't hesitate to contact us."
msgstr "Si tiene alguna pregunta o inquietud, no dude en contactarnos."

